<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dansk Vibe Vocab</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>🇩🇰 Dansk Vibe</h1>
        <div id="card" class="card">
            <div class="image-container">
                <img id="vocab-image" src="https://via.placeholder.com/300x200?text=Vibe+Loading..." alt="Routine Image">
            </div>
            <h2 id="danish-word">Henter ord...</h2>
            <p id="english-meaning" class="hidden"></p>
            
            <button id="flip-btn" class="main-btn">Show Answer</button>
            
            <div id="controls" class="buttons hidden">
                <button class="btn hard" onclick="rate(1)">Hard</button>
                <button class="btn good" onclick="rate(3)">Good</button>
                <button class="btn easy" onclick="rate(5)">Easy</button>
            </div>
        </div>
        <p class="stats">Words mastered: <span id="mastered-count">0</span></p>
    </div>
    <script src="script.js"></script>
</body>
</html>
